{
  "name": "chess-analyzer-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Chess Analyzer desktop app with Stockfish",
  "author": "Victor Simion",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.chess.analyzer",
    "productName": "Chess Analyzer",
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/engines",
        "to": "engines"
      }
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "publish": null
  }
}